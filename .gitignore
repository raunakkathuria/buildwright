.claude/agents/
.claude/claws/
.claude/commands/
.claude/steering/
.claude/tasks/

# Claude Code — user-specific local settings
.claude/settings.local.json

# OpenCode — entire directory is generated
.opencode/

# Cursor — generated from .buildwright/ by: make sync
.cursor/rules/

# AGENTS.md — generated from CLAUDE.md for OpenCode compatibility
AGENTS.md
