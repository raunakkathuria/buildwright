# Environment
.env
.env.*
!.env.example
*.local

# OS
.DS_Store

# npm CLI package — local dev dependencies
cli/node_modules/
# Temporary file written by prepack.js, removed by postpack.js
cli/.symlink-map.json

# ============================================================================
# Generated directories — DO NOT COMMIT
# These are generated from .buildwright/ (canonical) by: make sync
# ============================================================================

# Claude Code — generated dirs (sync rewrites .buildwright/ → .claude/ paths)
.claude/agents/
.claude/commands/
.claude/framework/
.claude/steering/
.claude/skills/

# Claude Code — user-specific local settings
.claude/settings.local.json

# OpenCode — entire directory is generated
.opencode/

# Cursor — generated from .buildwright/ by: make sync
.cursor/rules/

# Codex CLI — generated from .buildwright/commands/ by: make sync
/skills/
